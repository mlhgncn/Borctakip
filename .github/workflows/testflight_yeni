name: TestFlight Yeni Sabit

on:
  workflow_dispatch:
  push:
    branches:
      - main

jobs:
  ios:
    permissions:
      contents: write
    runs-on: macos-latest

    steps:
      - name: Select Latest Available Xcode
        run: |
          if [ -d "/Applications/Xcode_26.5.app" ]; then
            sudo xcode-select -s /Applications/Xcode_26.5.app/Contents/Developer
          else
            LATEST_XCODE=$(ls -d /Applications/Xcode*.app | tail -n 1)
            sudo xcode-select -s "$LATEST_XCODE/Contents/Developer"
          fi

      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Volta (Enforce Node 22 globally)
        uses: volta-cli/action@v4
        with:
          node-version: '22'

      - name: Set up Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: '3.2'
          bundler-cache: true

      - name: Force Custom Fresh Install
        run: |
          npm config set cache /Users/runner/.npm-custom-cache --global
          rm -rf node_modules package-lock.json
          npm install --legacy-peer-deps
          npm install ajv@^8.0.0 ajv-keywords@^5.0.0 --save-dev --legacy-peer-deps
          npm install @capacitor/ios@latest --legacy-peer-deps

      - name: Build Web Assets
        env:
          CI: false
        run: |
          npm run build --if-present

      - name: Capacitor Sync
        run: npx cap sync ios

      # ✨ BURAYI GARANTİYE ALDIK: Sunucu eski kodda ısrar etse bile artık iOS 16.0 basacak!
      - name: Auto-Fix and Install CocoaPods
        run: |
          cd ios/App
          # Eski veya hatalı her şeyi temizle
          rm -f Podfile Podfile.lock
          # Capacitor'ın kendi otomatik Podfile oluşturma mekanizmasını tetikle
          npx cap migrate --yes || true
          npx cap sync ios
          # Sorunsuz kurulum yap
          pod install --repo-update
          cd ../..

      - name: Install Ruby Gems (Fastlane)
        run: bundle install

      - name: Build and upload to TestFlight
        env:
          APP_STORE_CONNECT_API_KEY_ID: ${{ secrets.APP_STORE_CONNECT_API_KEY_ID }}
          APP_STORE_CONNECT_API_KEY_ISSUER_ID: ${{ secrets.APP_STORE_CONNECT_API_KEY_ISSUER_ID }}
          APP_STORE_CONNECT_API_KEY_CONTENT: ${{ secrets.APP_STORE_CONNECT_API_KEY_CONTENT }}
          FASTLANE_APPLE_ID: ${{ secrets.FASTLANE_APPLE_ID }}
          APPLE_DEVELOPER_TEAM_ID: ${{ secrets.APPLE_DEVELOPER_TEAM_ID }}
          APP_STORE_CONNECT_TEAM_ID: ${{ secrets.APP_STORE_CONNECT_TEAM_ID }}
          MATCH_PASSWORD: ${{ secrets.MATCH_PASSWORD }}
          BUNDLE_ID: com.borctakip.mobile.app
          MATCH_GIT_URL: "https://x-access-token:${{ secrets.MATCH_GIT_TOKEN }}@github.com/mlhgncn/ios-certificates.git"
        run: bundle exec fastlane ios release
