default_platform(:ios)

platform :ios do
  desc "Release lane for building and uploading to TestFlight"
  lane :release do
    setup_ci if is_ci

    # Setup API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      in_house: false
    )

    # Match - Download certificates and provisioning profiles
    match(
      type: "appstore",
      app_identifier: ["com.borctakip.mobile.app"],
      api_key: api_key,
      readonly: false,
      force_for_new_certificates: false,
      include_all_certificates: true,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
      git_url: ENV["MATCH_GIT_URL"],
      storage_mode: "git",
      git_branch: "main"
    )

    # Get the provisioning profile name from match
    profile_name = Actions.lane_context[SharedValues::SIGH_PROFILE_NAME]
    
    # Build the app
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      derived_data_path: "build",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      signingStyle: "manual",
      signingCertificate: "Apple Distribution",
      provisioningProfileSpecifier: profile_name,
      xcargs: "DEVELOPMENT_TEAM=B689345RR6 CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'",
      output_directory: "build",
      output_name: "App.ipa",
      buildlog_path: "build/logs"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.borctakip.mobile.app",
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      ipa: "build/App.ipa"
    )

    puts("Build and upload to TestFlight completed successfully!")
  end
end
